DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plz_app

# URL der Frontend-App (für CORS und E-Mail-Links)
APP_URL=https://app.standard-grid.com

# Geheimer Schlüssel für JWT-Session-Tokens (beliebiger langer zufälliger String)
JWT_SECRET=bitte-durch-langen-zufaelligen-string-ersetzen

# ── E-Mail (optional, aber für Einladungen empfohlen) ─────────────────────────
# Wenn SMTP_HOST leer ist, werden Links nur ins Server-Log geschrieben (gut für Entwicklung)

# Gmail-Beispiel:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=deine@gmail.com
#   SMTP_PASSWORD=dein-app-passwort  (nicht dein normales PW, App-Passwort in Google-Konto)

# Resend-Beispiel (einfachste Option, kostenloser Plan: 3000 E-Mails/Monat):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USER=resend
#   SMTP_PASSWORD=re_dein_api_key

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=standardgrid <noreply@standard-grid.com>
