DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plz_app
FRONTEND_ORIGIN=http://localhost:5173

# Cloudflare Access JWT-Verifikation
# Team-Domain: Cloudflare Dashboard → Access → Overview → "Your team domain"
# z.B. "mein-team.cloudflareaccess.com"
CF_ACCESS_TEAM_DOMAIN=mein-team.cloudflareaccess.com

# Application Audience Tag: Cloudflare Dashboard → Access → Applications → deine App → "Application Audience (AUD) Tag"
CF_ACCESS_AUD=abc123...
